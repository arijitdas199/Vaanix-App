{
  "project_name": "Vaanix",
  "tagline": "Connect Beyond Words",
  "theme": "Jewel & Luxury / Soft Premium",
  "archetype": "5 (Jewel & Luxury blended with Mobile Soft UI)",
  "instructions_to_main_agent": [
    "Follow this blueprint strictly for an Expo React Native environment.",
    "Never use generic fonts like Inter, Roboto, or Open Sans. Use Outfit for headings and Manrope for body text.",
    "Implement Material Design 3 spacing and interactions with a premium twist (extra breathing room, soft drop shadows instead of harsh elevation).",
    "Use the exact Indigo/Violet color hex codes provided for both Light and Dark modes. The gradient should be applied seamlessly.",
    "Chat bubbles must use asymmetric border-radii for directional indication (e.g., 24px on 3 corners, 4px on the tail corner).",
    "For avatars and missing user info, use the provided placeholder media URLs. Do not leave blank or text-only if media is intended.",
    "Every key interaction must use smooth animations, like react-native-reanimated for spring-based bottom sheets and chat bubble pop-ins.",
    "All interactive UI components MUST have 'testID' matching their function (e.g., testID='chat-list-item-0' since it is React Native, use testID instead of data-testid).",
    "Expo Navigation: Use @react-navigation/bottom-tabs for the primary navigation."
  ],
  "typography": {
    "font_family": {
      "heading": "Outfit, sans-serif",
      "body": "Manrope, sans-serif",
      "mono": "Space Mono, monospace"
    },
